{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./out-tsc/vitest",
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable"
    ],
    "types": [
      "vitest/globals",
      "happy-dom",
      "vite/client"
    ]
  },
  "include": [
    "vite.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
